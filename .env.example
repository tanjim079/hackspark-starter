# RentPi/.env.example
# You can change this file according to your need and stack.
# Copy this to .env and fill in your values before running docker-compose.
# Never commit your .env file.

# ── Central API ───────────────────────────────────────────────────────────────
# Your team token — received from the judges
CENTRAL_API_URL=https://technocracy.brittoo.xyz
CENTRAL_API_TOKEN=your_team_token_here

# ── Local Postgres (user-service) ─────────────────────────────────────────────
POSTGRES_USER=rentpi
POSTGRES_PASSWORD=localpassword
POSTGRES_DB=rentpi_local
DATABASE_URL=postgresql://rentpi:localpassword@postgres:5432/rentpi_local

# ── MongoDB (agentic-service) ──────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/rentpi_agentic

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_something_long_and_random

# ── AI Provider ───────────────────────────────────────────────────────────────
# Gemini (recommended — free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# OR OpenAI, Groq, etc — whichever you choose
# OPENAI_API_KEY=
# GROQ_API_KEY=

# ── Service Ports (don't change — used by docker-compose) ─────────────────────
GATEWAY_PORT=8000
USER_SERVICE_PORT=8001
RENTAL_SERVICE_PORT=8002
ANALYTICS_SERVICE_PORT=8003
AGENTIC_SERVICE_PORT=8004
FRONTEND_PORT=3000